{
  "name": "yielix-staffapp",
  "version": "1.1.0",
  "description": "YIELIX StaffApp - Real-time venue alerts for your POS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "keywords": ["yielix", "staffapp", "pos", "voucher"],
  "author": "YIELIX",
  "license": "ISC",
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "YIELIX StaffApp",
        "executableName": "yielix-staffapp",
        "icon": "./assets/icon",
        "appBundleId": "com.yielix.staffapp",
        "appCategoryType": "public.app-category.business",
        "osxSign": false
      },
      "makers": [
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "format": "ULFO",
            "name": "YIELIX-StaffApp",
            "icon": "./assets/icon.icns"
          }
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "YIELIX-StaffApp",
            "setupExe": "YIELIX-StaffApp-Setup.exe",
            "setupIcon": "./assets/icon.ico"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["darwin", "linux"]
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "^41.0.0",
    "electron-store": "^11.0.2"
  }
}
